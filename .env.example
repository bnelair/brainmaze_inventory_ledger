# ─────────────────────────────────────────────────────────────────────────────
# Brainmaze Inventory Ledger – Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────

# Host port to expose the Streamlit web UI on
APP_PORT=8501

# ── Git Synchronisation ──────────────────────────────────────────────────────

# Authentication method for the remote repository
#   PAT  – Personal Access Token (default, HTTPS)
#   SSH  – SSH key pair (requires mounting ~/.ssh directory)
#   APP  – GitHub/GitLab App or Bot account (token via GIT_TOKEN)
GIT_AUTH_METHOD=PAT

# Personal Access Token (PAT) or App token  [PAT / APP auth only]
GIT_TOKEN=

# Full URL of the remote repository that stores inventory data
#   HTTPS example:  https://github.com/org/inventory-data.git
#   SSH example:    git@github.com:org/inventory-data.git
GIT_REPO_URL=

# Branch to push/pull inventory data
GIT_BRANCH=main

# Commit author identity
GIT_USER_NAME=Brainmaze Bot
GIT_USER_EMAIL=brainmaze@lab.local

# ── SSH Keys (SSH auth only) ──────────────────────────────────────────────────

# Directory containing your SSH private key(s).
# The Docker Compose file mounts this as /root/.ssh:ro inside the container.
# Default: ~/.ssh  (your home directory's .ssh folder)
SSH_DIR=~/.ssh

# ── git-crypt (optional, for encrypted private repositories) ─────────────────

# Symmetric unlock key encoded as Base64.
# Generate with:  git-crypt export-key /tmp/key && base64 /tmp/key
GIT_CRYPT_KEY=
